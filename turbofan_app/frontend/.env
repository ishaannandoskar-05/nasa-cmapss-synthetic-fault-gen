# BUG-017 fix: API base URL is now an environment variable so it can be
# overridden without touching source code (e.g. for staging/production).
#
# Override for production:
#   VITE_API_BASE=https://your-backend.example.com/api
#
# Must be prefixed with VITE_ so Vite exposes it to the browser bundle.
VITE_API_BASE=http://localhost:5000/api
